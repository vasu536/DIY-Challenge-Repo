# ══════════════════════════════════════════════════════════════════════════════
# DIY Challenge Robot — Jetson Nano Profile
# ══════════════════════════════════════════════════════════════════════════════
# Load this file before any launch script:
#   source profiles/jetson.env
#
# This profile activates the FULL competition hardware stack:
#   • Hesai QT64 lidar (UDP Ethernet, from HesaiLidar_ROS_2.0)
#   • RealSense D435i  (USB 3, infra1/2 + IMU)
#   • STM32 E-stop + motor drive (via micro-ROS serial bridge)
#   • RTK GPS (serial NMEA)
#   • FAST-LIO2 + EKF1/EKF2 localisation
#   • Nav2 autonomous navigation

export DIY_ROBOT_PROFILE=jetson

# ── Hardware enables ────────────────────────────────────────────────────────
export DIY_USE_HESAI=true          # Hesai QT64 lidar
export DIY_USE_REALSENSE=true      # RealSense D435i
export DIY_USE_GPS=true            # RTK GPS
export DIY_USE_MICRO_ROS=true      # micro-ROS (STM32 bridge)
export DIY_USE_MOTOR_DRIVER=true   # differential-drive motor node

# ── Nav / SLAM modes ────────────────────────────────────────────────────────
export DIY_USE_NAV2=true           # Nav2 stack
export DIY_USE_LOCALIZATION=true   # FAST-LIO2 + EKF
export DIY_MUX_MODE=AUTONOMOUS     # cmd_vel_mux default mode at startup
export DIY_FASTLIO_CONFIG=fast_lio_hesai_qt64.yaml

# ── Hesai driver network ─────────────────────────────────────────────────────
# CALIB: Update if lidar IP or port is different on your Jetson setup.
export DIY_HESAI_IP=192.168.1.201
export DIY_HESAI_PORT=2368
export DIY_HESAI_FRAME_ID=lidar_link

# ── micro-ROS serial bridge ──────────────────────────────────────────────────
# CALIB: Confirm USB serial device path on Jetson.
export DIY_MICRO_ROS_SERIAL=/dev/ttyACM0
export DIY_MICRO_ROS_BAUDRATE=921600

# ── Recording defaults ───────────────────────────────────────────────────────
export DIY_BAG_OUTPUT_DIR=/mnt/usb/bags   # fast USB SSD recommended on Jetson
export DIY_BAG_SPLIT_DURATION=300         # split bags every 5 min

# ── Source overlay sequence ──────────────────────────────────────────────────
# env.sh will source these in order — override individual elements here.
export DIY_ROS_WS="${HOME}/ros2_ws"
export DIY_THIRD_PARTY_WS="${DIY_ROS_WS}/src/DIY-Challenge-Repo/third_party_ws"
export DIY_HESAI_WS="${DIY_ROS_WS}/src/Betsybot-Software/src/HesaiLidar_ROS_2.0"
export DIY_MICRO_ROS_WS="${HOME}/micro_ros_ws"

echo "[DIY] Profile loaded: JETSON (full competition hardware)"
