# ══════════════════════════════════════════════════════════════════════════════
# DIY Challenge Robot — Raspberry Pi Profile
# ══════════════════════════════════════════════════════════════════════════════
# Load this file before any launch script:
#   source profiles/raspi.env
#
# This profile activates the LIGHTWEIGHT relay+health role:
#   • micro-ROS serial bridge (STM32 E-stop + motor drive only)
#   • No heavy sensors — lidar and depth camera handled by Jetson
#   • Health monitoring node + watchdog relay
#   • No SLAM / Nav2 (compute insufficient on Pi 4)
#   • Optional: low-rate GPS relay to Jetson over DDS

export DIY_ROBOT_PROFILE=raspi

# ── Hardware enables ────────────────────────────────────────────────────────
export DIY_USE_HESAI=false         # Lidar on Jetson
export DIY_USE_REALSENSE=false     # Camera on Jetson
export DIY_USE_GPS=true            # RTK GPS — relay to Jetson via DDS
export DIY_USE_MICRO_ROS=true      # micro-ROS (STM32 bridge)
export DIY_USE_MOTOR_DRIVER=true   # differential-drive motor node

# ── Nav / SLAM modes ────────────────────────────────────────────────────────
export DIY_USE_NAV2=false          # Nav2 not on Pi
export DIY_USE_LOCALIZATION=false  # SLAM not on Pi
export DIY_MUX_MODE=JOYSTICK       # Pi starts in joystick mode for safety
export DIY_FASTLIO_CONFIG=         # N/A

# ── micro-ROS serial bridge ──────────────────────────────────────────────────
# CALIB: Confirm USB serial device path on your Pi setup.
export DIY_MICRO_ROS_SERIAL=/dev/ttyACM0
export DIY_MICRO_ROS_BAUDRATE=921600

# ── Recording defaults ───────────────────────────────────────────────────────
export DIY_BAG_OUTPUT_DIR="${HOME}/bags"
export DIY_BAG_SPLIT_DURATION=300

# ── Source overlay sequence ──────────────────────────────────────────────────
export DIY_ROS_WS="${HOME}/ros2_ws"
export DIY_THIRD_PARTY_WS="${DIY_ROS_WS}/src/DIY-Challenge-Repo/third_party_ws"
export DIY_HESAI_WS=""             # not needed on Pi
export DIY_MICRO_ROS_WS="${HOME}/micro_ros_ws"

echo "[DIY] Profile loaded: RASPI (lightweight relay/health)"
