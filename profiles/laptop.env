# ══════════════════════════════════════════════════════════════════════════════
# DIY Challenge Robot — Laptop / Developer Profile
# ══════════════════════════════════════════════════════════════════════════════
# Load this file before any launch script:
#   source profiles/laptop.env
#
# This profile activates the DEBUG / REPLAY / CALIBRATION mode:
#   • No hardware drivers — all sensors are mocked or replayed from bag
#   • RViz enabled by default
#   • rosbag replay supported
#   • Calibration tool launches available
#   • Nav2 + SLAM can run against replayed sensor data

export DIY_ROBOT_PROFILE=laptop

# ── Hardware enables ────────────────────────────────────────────────────────
export DIY_USE_HESAI=false         # No lidar hardware on laptop
export DIY_USE_REALSENSE=false     # No camera hardware on laptop
export DIY_USE_GPS=false           # GPS from bag only
export DIY_USE_MICRO_ROS=false     # No STM32 on laptop
export DIY_USE_MOTOR_DRIVER=false  # No motors on laptop

# ── Nav / SLAM modes ────────────────────────────────────────────────────────
export DIY_USE_NAV2=true           # Start Nav2 against replayed data
export DIY_USE_LOCALIZATION=true   # Run FAST-LIO2 against replayed lidar
export DIY_MUX_MODE=AUTONOMOUS     # Allow Nav2 to drive during replay
export DIY_FASTLIO_CONFIG=fast_lio_hesai_qt64.yaml

# ── Developer tools ─────────────────────────────────────────────────────────
export DIY_USE_RVIZ=true           # Open RViz on launch
export DIY_LOG_LEVEL=DEBUG         # Verbose ROS logging

# ── Recording defaults ───────────────────────────────────────────────────────
export DIY_BAG_OUTPUT_DIR="${HOME}/bags"
export DIY_BAG_SPLIT_DURATION=600  # Longer splits ok on laptop SSD

# ── Source overlay sequence ──────────────────────────────────────────────────
export DIY_ROS_WS="${HOME}/ros2_ws"
export DIY_THIRD_PARTY_WS="${DIY_ROS_WS}/src/DIY-Challenge-Repo/third_party_ws"
export DIY_HESAI_WS="${DIY_ROS_WS}/src/Betsybot-Software/src/HesaiLidar_ROS_2.0"
export DIY_MICRO_ROS_WS="${HOME}/micro_ros_ws"

echo "[DIY] Profile loaded: LAPTOP (debug/replay/calibration)"
